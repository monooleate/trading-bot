---
import Base from "../../layouts/Base.astro";
import CategoryDashboard from "../../components/CategoryDashboard.tsx";

export function getStaticPaths() {
  return [
    { params: { category: "crypto" } },
    { params: { category: "weather" } },
    { params: { category: "hyperliquid" } },
    { params: { category: "bybit" } },
    { params: { category: "binance" } },
    { params: { category: "polymarket-manual" } },
  ];
}

const { category } = Astro.params;
---
<Base>
  <CategoryDashboard category={category} client:only="react" />
</Base>
